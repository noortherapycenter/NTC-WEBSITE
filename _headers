# Only the paths listed below require a login — the public website is unaffected.
# CHANGE THE PASSWORD below before deploying, then keep this file out of any public repo.

/admin.html
  Basic-Auth: noorstaff:Admission1!

/admin
  Basic-Auth: noorstaff:Admission1!

/admin/*
  Basic-Auth: noorstaff:Admission1!

/staff-portal/*
